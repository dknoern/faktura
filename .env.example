# Encryption key for tenant secrets stored at rest (AES-256-GCM):
# Stripe restricted keys, AvaTax license keys, etc.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Must base64-decode to exactly 32 bytes. Losing this value makes every stored
# tenant secret unrecoverable; admins would need to re-enter them.
CREDENTIALS_ENCRYPTION_KEY=